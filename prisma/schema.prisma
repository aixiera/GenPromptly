generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model User {
  id              String       @id @default(cuid())
  clerkUserId     String       @unique
  email           String       @unique
  name            String?
  lastActiveOrgId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  memberships     Membership[]
  invitesSent     Invite[]     @relation("InviteInvitedBy")
  invitesAccepted Invite[]     @relation("InviteAcceptedBy")
  auditLogs       AuditLog[]   @relation("AuditLogActor")
  usage           Usage[]
  lastActiveOrg   Organization? @relation("UserLastActiveOrg", fields: [lastActiveOrgId], references: [id], onDelete: SetNull)

  @@index([lastActiveOrgId])
  @@index([createdAt])
}

model Organization {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  memberships    Membership[]
  usersLastActive User[]        @relation("UserLastActiveOrg")
  projects       Project[]
  prompts        Prompt[]
  promptVersions PromptVersion[]
  auditLogs      AuditLog[]
  usage          Usage[]
  invites        Invite[]

  @@index([updatedAt])
}

model Membership {
  id        String           @id @default(cuid())
  orgId     String
  userId    String
  role      OrganizationRole @default(MEMBER)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  org       Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId, role])
  @@index([userId])
}

model Invite {
  id               String           @id @default(cuid())
  orgId            String
  email            String
  role             OrganizationRole @default(MEMBER)
  token            String           @unique
  status           InviteStatus     @default(PENDING)
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  org              Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy        User             @relation("InviteInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedBy       User?            @relation("InviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([email])
  @@index([orgId, status])
  @@index([orgId, email, status])
}

model Project {
  id           String       @id @default(cuid())
  name         String
  orgId        String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  prompts      Prompt[]
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, updatedAt])
}

model Prompt {
  id           String         @id @default(cuid())
  projectId    String
  orgId        String
  templateId   String?
  title        String
  rawPrompt    String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  versions     PromptVersion[]
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  template     Template?      @relation(fields: [templateId], references: [id])

  @@index([projectId])
  @@index([orgId])
  @@index([templateId])
  @@index([orgId, projectId])
  @@index([orgId, updatedAt])
}

model PromptVersion {
  id              String       @id @default(cuid())
  promptId        String
  orgId           String
  optimizedPrompt String
  keyChanges      Json
  scores          Json
  missingFields   Json
  riskFlags       Json
  rawInputPrompt  String
  mode            String
  model           String
  tokenIn         Int?
  tokenOut        Int?
  createdAt       DateTime     @default(now())
  prompt          Prompt       @relation(fields: [promptId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@index([orgId, createdAt])
}

model AuditLog {
  id           String       @id @default(cuid())
  orgId        String
  userId       String?
  action       String
  resourceType String
  resourceId   String
  metadata     Json
  ipAddress    String?
  userAgent    String?
  requestId    String?
  createdAt    DateTime     @default(now())
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?        @relation("AuditLogActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([orgId, action, createdAt])
  @@index([orgId, resourceType, resourceId])
}

model Usage {
  id           String       @id @default(cuid())
  orgId        String
  userId       String
  model        String
  tokenIn      Int          @default(0)
  tokenOut     Int          @default(0)
  costUsd      Decimal?     @db.Decimal(12, 6)
  requestId    String?
  templateName String?
  createdAt    DateTime     @default(now())
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([orgId, userId, createdAt])
  @@index([requestId])
}

model Template {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String
  description  String
  category     String
  inputSchema  Json
  systemPrompt String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  prompts      Prompt[]
}
